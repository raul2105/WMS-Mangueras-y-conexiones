{
  "name": "wms-scmayher",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:webpack": "next dev --webpack -p 3002",
    "build": "next build --webpack",
    "start": "next start -p 3002",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "node scripts/db/run-vitest-postgres.cjs run",
    "test:sqlite": "node scripts/db/run-vitest-sqlite.cjs run",
    "test:postgres": "node scripts/db/run-vitest-postgres.cjs run",
    "smoke:published": "node scripts/smoke/published-links.cjs",
    "smoke:web": "node scripts/smoke/web-runtime.cjs",
    "smoke:mobile-auth": "node scripts/smoke/validate-mobile-auth.cjs",
    "env:postgres:check": "node scripts/db/assert-postgres-env.cjs",
    "env:postgres:tcp": "node scripts/db/assert-postgres-env.cjs --check-connection",
    "sync:daily:report": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\ops\\daily-sync-report.ps1 -JiraProject KAN",
    "sync:jira:views": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\ops\\sync-jira-views.ps1 -JiraProject KAN",
    "test:rbac": "node scripts/db/run-vitest-postgres.cjs run tests/rbac",
    "test:rbac:unit": "node scripts/db/run-vitest-postgres.cjs run tests/rbac/permissions.test.ts tests/rbac/require-permission.test.ts",
    "test:rbac:integration": "node scripts/db/run-vitest-postgres.cjs run tests/rbac/route-access.integration.test.ts tests/rbac/server-actions-guards.integration.test.ts tests/rbac/fixtures.integration.test.ts",
    "test:customers:contracts": "node scripts/db/run-vitest-postgres.cjs run tests/customers/postgresql-schema.contract.test.ts tests/customers/customer-search-api.contract.test.ts tests/customers/request-new-customer-ui.contract.test.ts tests/customers/request-new-customer-page.runtime.test.ts tests/customers/sales-requests-customer-fallback.contract.test.ts",
    "test:sales:service": "node scripts/db/run-vitest-postgres.cjs run tests/sales-request-service.test.ts",
    "test:customers:postgres": "node scripts/db/run-vitest-postgres.cjs run tests/customers/postgresql-customer-order.integration.test.ts",
    "test:regression:postgres": "node scripts/db/run-vitest-postgres.cjs run --maxWorkers=1 tests/rbac/permissions.test.ts tests/rbac/require-permission.test.ts tests/rbac/route-access.integration.test.ts tests/rbac/server-actions-guards.integration.test.ts tests/rbac/fixtures.integration.test.ts tests/customers/customer-service.test.ts tests/customers/postgresql-schema.contract.test.ts tests/customers/customer-search-api.contract.test.ts tests/customers/customer-quick-create-api.contract.test.ts tests/customers/customer-quick-create-api.runtime.test.ts tests/customers/request-new-customer-ui.contract.test.ts tests/customers/request-new-customer-page.runtime.test.ts tests/customers/sales-requests-customer-fallback.contract.test.ts tests/customers/postgresql-customer-order.integration.test.ts tests/users/admin-service.integration.test.ts tests/users/auth-login.integration.test.ts tests/dashboard/fulfillment-signals.unit.test.ts tests/dashboard/fulfillment-dashboard.integration.test.ts tests/sales-internal-order-flow.test.ts tests/sales-request-service.test.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install",
    "postinstall": "node scripts/db/generate-default-prisma-client.cjs",
    "prisma:validate": "node scripts/db/validate-prisma-schemas.cjs",
    "prisma:generate": "node scripts/db/generate-default-prisma-client.cjs",
    "prisma:generate:aws": "node scripts/db/generate-aws-prisma-client.cjs",
    "verify:release": "npm run prisma:validate && npm run prisma:generate && npm run typecheck && npm run test:postgres && npm run build",
    "build:release": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\release\\build-release.ps1",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push --accept-data-loss",
    "db:setup": "npm run db:push && npm run db:seed",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "import:products": "node scripts/data/import-products-from-csv.cjs",
    "link:product-images": "node scripts/data/link-product-images-from-folder.cjs",
    "populate:subcategories": "node scripts/data/populate-product-subcategories.cjs",
    "reindex:attributes": "node scripts/data/reindex-product-attributes.cjs",
    "customers:backfill:dry": "node scripts/data/backfill-customers-from-sales-orders.cjs --dry-run",
    "customers:backfill:apply": "node scripts/data/backfill-customers-from-sales-orders.cjs --apply --link-orders --confirm",
    "mobile:infra:synth": "npm --prefix mobile/infra/cdk run synth",
    "mobile:infra:diff": "npm --prefix mobile/infra/cdk run diff",
    "mobile:infra:deploy": "npm --prefix mobile/infra/cdk run deploy",
    "mobile:infra:destroy": "npm --prefix mobile/infra/cdk exec cdk destroy",
    "mobile:staging:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy\\mobile-staging.ps1",
    "mobile:bootstrap:read-models": "node scripts/mobile/bootstrap-read-models.cjs",
    "mobile:config:generate": "node scripts/mobile/generate-mobile-config.cjs",
    "build:opennext": "npx @opennextjs/aws build",
    "deploy:aws:web": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy\\aws-web.ps1",
    "infra:synth": "npm --prefix infra/cdk run synth",
    "infra:deploy": "npm --prefix infra/cdk run deploy",
    "infra:diff": "npm --prefix infra/cdk run diff"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1029.0",
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/client-sqs": "^3.1029.0",
    "@prisma/client": "6.19.2",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^5.6.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.31",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@opennextjs/aws": "^3.10.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}


