{
  "name": "wms-rigentec",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "next dev --webpack -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install",
    "postinstall": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "verify:release": "npm run prisma:validate && npm run prisma:generate && npm run typecheck && npm run test && npm run build",
    "build:release": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-release.ps1",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push --accept-data-loss",
    "db:setup": "npm run db:push && npm run db:seed",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "import:products": "node scripts/import-products-from-csv.cjs",
    "link:product-images": "node scripts/link-product-images-from-folder.cjs",
    "populate:subcategories": "node scripts/populate-product-subcategories.cjs",
    "reindex:attributes": "node scripts/reindex-product-attributes.cjs"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "csv-parse": "^5.6.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  }
}
