# AWS profile for CLI/CDK operations
AWS_PROFILE=Rigentec-SCMayer

# Deployment target environment and region
MOBILE_ENV=dev
MOBILE_AWS_REGION=us-east-1

# Build metadata exposed by /v1/mobile/version
MOBILE_BUILD=dev
MOBILE_RELEASE_DATE=2026-04-07

# Runtime flags (keep all false by default for safe rollout)
MOBILE_ENABLED=false
INVENTORY_SEARCH_ENABLED=false
ASSEMBLY_REQUESTS_ENABLED=false
PRODUCT_DRAFTS_ENABLED=false

# Runtime service mode
MOBILE_AUTH_MODE=cognito
MOBILE_SERVICE_NAME=wms-mobile-edge

# Runtime resources (provided by stack outputs after deploy)
MOBILE_DDB_INVENTORY_TABLE=
MOBILE_DDB_ASSEMBLY_REQUESTS_TABLE=
MOBILE_DDB_PRODUCT_DRAFTS_TABLE=
MOBILE_INTEGRATION_QUEUE_URL=
MOBILE_CORS_ALLOWED_ORIGIN=

# Public web shell config values
MOBILE_API_BASE_URL=
MOBILE_COGNITO_DOMAIN=
MOBILE_COGNITO_CLIENT_ID=
MOBILE_CALLBACK_URL=
MOBILE_LOGOUT_URL=
